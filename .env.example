# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_USERNAME=pimcore_frontend
ELASTICSEARCH_PASSWORD=

# Pimcore
# PIMCORE_BACKEND_URL is server-only (no NEXT_PUBLIC_ prefix) — used for prefixing image URLs server-side
PIMCORE_BACKEND_URL=http://skeleton.localhost
PIMCORE_API_URL=http://skeleton.localhost
PIMCORE_CLIENT_ID=
PIMCORE_CLIENT_SECRET=
