# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_USERNAME=pimcore_frontend
ELASTICSEARCH_PASSWORD=

# Pimcore API
PIMCORE_API_URL=http://skeleton.localhost
PIMCORE_CLIENT_ID=
PIMCORE_CLIENT_SECRET=

# Site configuration
# SITE_PREFIX is derived from the hostname automatically when not set.
# Set explicitly to override, e.g. "skeleton_localhost" for skeleton-fe.localhost.
SITE_PREFIX=
DEFAULT_LOCALE=cs
AVAILABLE_LOCALES=cs,en

# Next.js public variables (exposed to client-side code)
NEXT_PUBLIC_SITE_URL=http://skeleton-fe.localhost
